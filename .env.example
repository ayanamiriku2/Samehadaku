# Environment variables - copy to .env and fill in your values
# cp .env.example .env

# Source website
SOURCE_DOMAIN=v2.samehadaku.how
SOURCE_SCHEME=https

# Your mirror domain (WAJIB DIISI dengan domain kamu)
MIRROR_DOMAIN=yourdomain.com
MIRROR_SCHEME=https

# Cache settings
CACHE_ENABLED=true
CACHE_DIR=/tmp/mirror_cache
CACHE_TTL_HTML=300
CACHE_TTL_ASSETS=86400
CACHE_TTL_API=60

# Server
PORT=8000
HOST=0.0.0.0
WORKERS=4

# Browser impersonation for Cloudflare bypass
# Options: chrome, chrome110, chrome116, chrome120, safari, safari_ios, edge
IMPERSONATE_BROWSER=chrome

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# Custom SEO (optional)
CUSTOM_META_DESCRIPTION=
CUSTOM_SITE_TITLE_SUFFIX=
